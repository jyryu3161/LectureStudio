# =============================================================================
# .env.production.example — Lecture Studio production environment variables.
#
# Copy to your host's secret store (Vercel Project Env, Fly secrets, etc.).
# PLACEHOLDERS ONLY — never commit real keys. See docs/02-deployment.md.
#
# Two runtimes share ONE Supabase project:
#   [A] Next.js app   → Vercel (or any Node host)
#   [W] Standalone worker → a Docker host (NOT Vercel — see docs/02-deployment.md)
# The column tags below say which runtime needs each var.
# =============================================================================

# --- Supabase (project API settings → Project Settings → API) ----------------
# [A][W] Public project URL. Safe to expose (shipped to the browser).
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co

# [A] Public anon key. Safe to expose; RLS is the real access control.
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# [A][W] Service-role key. SECRET — bypasses RLS. NEVER expose to the browser.
#   App: used ONLY server-side (Server Actions / RSC / route handlers), never
#        in Client Components. Worker: its sole DB credential.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# --- Worker-only tuning -------------------------------------------------------
# [W] Poll interval (ms) between job claims. Optional, default 1000.
WORKER_POLL_MS=1000

# [W] Remote Docker daemon, e.g. tcp://10.0.0.5:2376 (with TLS). Leave UNSET to
#     use a mounted /var/run/docker.sock instead. See the docker-in-docker
#     caveat in worker/Dockerfile. Optional.
# DOCKER_HOST=

# --- NOT env vars: things you might expect here but that live elsewhere -------
# AI PROVIDER KEYS (Anthropic / Google Gemini) are NOT read from env. They are
#   entered by a platform admin in the in-app Admin → LLM UI and stored in the
#   database (llm_providers / ai_* tables), so rotating a provider key is a UI
#   action, not a redeploy. Do not add ANTHROPIC_API_KEY / GOOGLE_API_KEY here.
#
# The marimo demos Storage bucket ('demos') is created PUBLIC-read by migration
#   0005_demos.sql and needs no env var. WASM bundles are served from its public
#   object URLs; only the worker (service role) can write to it.
